# 智能数据瞭望系统环境变量配置模板
# 复制此文件为 .env 并填入实际值

# Tornado Cookie Secret（用于会话加密）
COOKIE_SECRET=your_cookie_secret_here

# API Keys（用于调用大模型服务）
XISHIMEI_API_KEY=your_xishimei_api_key_here
WEATHER_API_KEY=your_weather_api_key_here
MUSIC_API_KEY=your_music_api_key_here

# 默认模型服务 Base URL
DEFAULT_MODEL_BASE_URL=https://api.example.com/v1

# 数据库路径（可选，默认为 database/app.db）
DATABASE_PATH=database/app.db